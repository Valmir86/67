<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>SIX SEVEN</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{

background:#0b0b0b;
color:white;
text-align:center;

}

header{

padding:25px;

background:#111;

border-bottom:2px solid #D4AF37;

box-shadow:0 0 20px #D4AF37;

}

h1{

color:#D4AF37;

font-size:38px;

letter-spacing:4px;

}

p{

color:#ddd;

}

.container{

padding:20px;

}

video{

width:95%;

max-width:420px;

border-radius:25px;

border:3px solid #D4AF37;

box-shadow:0 0 25px #D4AF37;

margin-top:20px;

}

button{

margin-top:20px;

padding:15px 35px;

font-size:18px;

background:#D4AF37;

color:black;

border:none;

border-radius:50px;

cursor:pointer;

font-weight:bold;

}

button:hover{

transform:scale(1.05);

}

.card{

background:#161616;

padding:20px;

margin-top:20px;

border-radius:20px;

width:95%;

max-width:450px;

margin-left:auto;

margin-right:auto;

border:1px solid #D4AF37;

box-shadow:0 0 15px rgba(212,175,55,.3);

}

h2{

color:#D4AF37;

margin-bottom:10px;

}

.barra{

height:22px;

background:#333;

border-radius:50px;

overflow:hidden;

margin-top:10px;

}

.preenchimento{

height:100%;

width:0;

background:linear-gradient(
90deg,
#D4AF37,
#F5D76E
);

transition:1s;

}

.valor{

margin-top:10px;

font-size:22px;

font-weight:bold;

}

#perfil{

font-size:32px;

margin-top:15px;

color:#F5D76E;

}

footer{

margin-top:40px;

padding:20px;

color:#888;

}

</style>

</head>

<body>

<header>

<h1>SIX SEVEN</h1>

<p>Black Gold Edition</p>

</header>

<div class="container">

<video
id="camera"
autoplay
playsinline>
</video>

<br>

<button onclick="iniciar()">

INICIAR ANÁLISE

</button>

<div class="card">

<h2>🌟 Energia</h2>

<div class="barra">

<div
class="preenchimento"
id="energiaBar">
</div>

</div>

<div
class="valor"
id="energia">

0%

</div>

</div>

<div class="card">

<h2>🧠 Presença</h2>

<div class="barra">

<div
class="preenchimento"
id="presencaBar">
</div>

</div>

<div
class="valor"
id="presenca">

0%

</div>

</div>

<div class="card">

<h2>⭐ Perfil</h2>

<div id="perfil">

-

</div>

</div>

</div>

<footer>

SIX SEVEN © 2026

</footer>

<script>

async function iniciar(){

try{

const stream =
await navigator
.mediaDevices
.getUserMedia({

video:true

});

camera.srcObject =
stream;

setTimeout(analisar,3000);

}
catch{

alert(
"Permita o acesso à câmera."
);

}

}

function analisar(){

const energia =
Math.floor(
Math.random()*100
);

const presenca =
Math.floor(
Math.random()*100
);

energiaBar.style.width =
energia+"%";

presencaBar.style.width =
presenca+"%";

energia.innerHTML =
energia+"%";

presenca.innerHTML =
presenca+"%";

const perfis=[

"LÍDER",

"CRIATIVO",

"ANALÍTICO",

"COMUNICADOR",

"EQUILIBRADO"

];

const sorteado =

perfis[

Math.floor(

Math.random()

*perfis.length

)

];

perfil.innerHTML =
sorteado;

}

</script>

</body>

</html>
